<% if params[:created] %>
  <div class="alert alert-success" role="alert">Punkt zapisany.</div>
<% end %>

<div class="d-flex align-items-center justify-content-between gap-3 mb-3">
  <div>
    <h1 class="h3 mb-1"><%= h(@observation["name"]) %></h1>
    <p class="text-secondary mb-0">Punkt #<%= @observation["id"] %> · Grupa <%= @observation["group_number"] || 1 %> · <%= h(format_time(@observation["created_at"])) %></p>
  </div>
  <a class="btn btn-outline-secondary" href="/observations">Lista</a>
</div>

<div class="detail-grid">
  <section>
    <div id="map" class="map detail-map" data-lat="<%= @observation["latitude"] %>" data-lng="<%= @observation["longitude"] %>" data-readonly="true"></div>
    <div class="mt-3 d-flex flex-wrap gap-2">
      <a class="btn btn-primary" href="<%= osm_link(@observation) %>" target="_blank" rel="noopener">Otwórz w OSM</a>
      <a class="btn btn-outline-secondary" href="/export.geojson?group=<%= @observation["group_number"] || 1 %>">GeoJSON grupy</a>
      <a class="btn btn-outline-secondary" href="/export.csv?group=<%= @observation["group_number"] || 1 %>">CSV grupy</a>
    </div>
  </section>

  <section class="detail-panel">
    <dl class="row mb-0">
      <dt class="col-sm-4">Nazwa</dt>
      <dd class="col-sm-8"><%= h(@observation["name"]) %></dd>
      <dt class="col-sm-4">Grupa</dt>
      <dd class="col-sm-8">Grupa <%= @observation["group_number"] || 1 %></dd>
      <dt class="col-sm-4">Opis</dt>
      <dd class="col-sm-8"><%= @observation["description"].to_s.empty? ? "-" : h(@observation["description"]) %></dd>
      <dt class="col-sm-4">Latitude</dt>
      <dd class="col-sm-8"><code><%= @observation["latitude"] %></code></dd>
      <dt class="col-sm-4">Longitude</dt>
      <dd class="col-sm-8"><code><%= @observation["longitude"] %></code></dd>
      <dt class="col-sm-4">Dokładność</dt>
      <dd class="col-sm-8"><%= @observation["accuracy"] ? "#{@observation["accuracy"].round} m" : "-" %></dd>
    </dl>

    <% photos = photos_for_observation(@observation["id"]) %>
    <% if photos.any? %>
      <div class="photo-grid mt-3">
        <% photos.each_with_index do |photo, index| %>
          <a href="<%= photo["path"] %>" target="_blank" rel="noopener">
            <img class="detail-photo" src="<%= photo["path"] %>" alt="Zdjęcie <%= index + 1 %> punktu <%= h(@observation["name"]) %>">
          </a>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
